def calculate():
    if not state["participants"]:
        messagebox.showwarning("경고", "참여 인원을 등록해주세요!")
        return
        
    if not state["items"]:
        messagebox.showwarning("경고", "품목을 최소 1개 이상 등록해주세요!")
        return
        
    # 결제자 비어있는 품목 있는지 검사
    for item in state["items"]:
        if not item["payer_name"]:
            messagebox.showwarning("경고", f"품목 [{item['name']}]의 선결제자가 지정되지 않았습니다. 수정 후 다시 계산해 주세요.")
            return
            
    # 정산 로직 구동용 데이터 객체 매핑
    participants_dict = {
        p["name"]: Participant(p["name"], p["bank"], p["account"])
        for p in state["participants"]
    }
    
    items_list = [
        Item(item["name"], item["cost"], item["payer_name"], item["participant_names"])
        for item in state["items"]
    ]
    
    rounding_unit = int(rounding_var.get())
    
    # 송금 최소화 연산 실행
    balances, transfers = calculate_dutch_pay(participants_dict, items_list, rounding_unit)
    
    # 텍스트 포맷팅
    result_text = format_results(participants_dict, items_list, transfers)
    
    # UI 출력 반영
    result_text_widget.config(state='normal')
    result_text_widget.delete('1.0', tk.END)
    result_text_widget.insert(tk.END, result_text)
    result_text_widget.config(state='disabled')

