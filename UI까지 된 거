            btn_hover = ACCENT_HOVER if is_active else '#334155'
            btn_fg = 'white' if is_active else TOGGLE_OFF_TEXT
            
            btn_text = p_name if is_active else f"{p_name} ✖"
            
            t_btn = create_button(
                btn_wrapper, 
                text=btn_text, 
                command=lambda i=item_id, name=p_name: toggle_item_participant(i, name),
