                hover_bg=btn_hover, 
                fg=btn_fg,
                font=(FONT_FAMILY, 8, 'bold'),
                padx=6,
                pady=3
            )
            
            row = idx // 4
            col = idx % 4
            t_btn.grid(row=row, column=col, padx=3, pady=3, sticky='nsew')
            
