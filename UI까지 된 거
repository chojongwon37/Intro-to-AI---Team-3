def add_participant():
    name = p_name_entry.get().strip()
    bank = p_bank_var.get()
    account = p_account_entry.get().strip()
    
    if not name:
        messagebox.showwarning("경고", "이름을 입력해 주세요.")
        return
        
    # 중복 체크
    if any(p["name"] == name for p in state["participants"]):
        messagebox.showwarning("경고", "이미 등록된 이름입니다. 다른 이름을 사용해주세요.")
        return
        
    state["participants"].append({
        "name": name,
        "bank": bank,
        "account": account
    })
    
    # 새 참여자를 기존 모든 품목에 정산 기본값(참여)으로 자동 추가
    for item in state["items"]:
        if name not in item["participant_names"]:
            item["participant_names"].append(name)
            
    p_name_entry.delete(0, tk.END)
    p_bank_var.set("")
    p_account_entry.delete(0, tk.END)
    
    render_all()

def delete_participant(name):
    # 참여자 목록에서 제외
    state["participants"] = [p for p in state["participants"] if p["name"] != name]
    
    # 품목 데이터에서도 제외
    for item in state["items"]:
        if name in item["participant_names"]:
            item["participant_names"].remove(name)
        if item["payer_name"] == name:
            item["payer_name"] = ""  # 결제자 비움
            
    render_all()

def add_item():
    if not state["participants"]:
        messagebox.showwarning("경고", "먼저 참여 인원을 등록해 주세요.")
        return
        
    name = item_name_entry.get().strip()
    cost_str = item_cost_entry.get().strip()
    payer = payer_var.get()
    
    if not name:
        messagebox.showwarning("경고", "품목명을 입력해 주세요.")
        return
    if not cost_str:
        messagebox.showwarning("경고", "금액을 입력해 주세요.")
        return
        
    try:
        cost = int(cost_str)
        if cost < 0:
            raise ValueError()
    except ValueError:
        messagebox.showwarning("경고", "금액은 올바른 양의 정수로 입력해 주세요.")
        return
        
    if not payer:
        messagebox.showwarning("경고", "먼저 결제한 선결제자를 선택해 주세요.")
        return
        
    state["item_counter"] += 1
    state["items"].append({
        "id": state["item_counter"],
        "name": name,
        "cost": cost,
        "payer_name": payer,
        "participant_names": [p["name"] for p in state["participants"]] # 전원 기본 참여
    })
    
    item_name_entry.delete(0, tk.END)
    item_cost_entry.delete(0, tk.END)
    
    render_all()

def delete_item(item_id):
    state["items"] = [item for item in state["items"] if item["id"] != item_id]
    render_all()

def toggle_item_participant(item_id, p_name):
    for item in state["items"]:
        if item["id"] == item_id:
            if p_name in item["participant_names"]:
                item["participant_names"].remove(p_name)
            else:
                item["participant_names"].append(p_name)
            break
    render_items()

