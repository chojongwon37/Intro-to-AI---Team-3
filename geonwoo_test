import cv2
import pytesseract
import pandas as pd
import numpy as np
import re
from google.colab import files
import io
from PIL import Image

# ==========================================
# ⬇️ 영수증 사진을 업로드하는 코드 부분입니다 ⬇️
# ==========================================
print("영수증 이미지 파일을 업로드해주세요 (jpg, png 등)")
uploaded = files.upload()
# ==========================================

# 업로드된 파일 처리
if not uploaded:
    print("업로드된 파일이 없습니다.")
else:
    # 첫 번째 업로드된 파일의 이름 가져오기
    filename = next(iter(uploaded))
    print(f"'{filename}' 파일 처리 중...")

    # 이미지를 OpenCV 배열로 변환
    image_bytes = uploaded[filename]
    image_array = np.frombuffer(image_bytes, dtype=np.uint8)
    img = cv2.imdecode(image_array, cv2.IMREAD_COLOR)

    # OCR 인식률을 높이기 위한 이미지 전처리 (흑백 변환)
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    
    # 이미지에서 텍스트 추출 (한국어+영어)
    custom_config = r'--oem 3 --psm 6'
    extracted_text = pytesseract.image_to_string(gray, lang='kor+eng', config=custom_config)
    
    print("\n--- [OCR 추출 원본 텍스트] ---")
    print(extracted_text)
    print("------------------------------\n")

    # 추출된 텍스트를 줄 단위로 분리
    lines = extracted_text.split('\n')
    
    parsed_data = []
    
    # 임시 파싱 로직 (영수증 양식에 따라 수정이 필요합니다)
    # 예시: '상품명  1,000  2  2,000' 형태의 줄을 찾는 간단한 정규식
    pattern = re.compile(r'(.*?)\s+([\d,]+)\s+(\d+)\s+([\d,]+)')

    for line in lines:
        line = line.strip()
        if not line:
            continue
            
        match = pattern.search(line)
        if match:
            item_name = match.group(1).strip()
            unit_price = match.group(2)
            quantity = match.group(3)
            total_price = match.group(4)
            
            # 상품명이 비어있지 않은 경우에만 추가
            if item_name:
                parsed_data.append([item_name, unit_price, quantity, total_price])

    # DataFrame 생성 및 CSV 파일로 저장
    if parsed_data:
        df = pd.DataFrame(parsed_data, columns=['상품명', '단가', '수량', '금액'])
        csv_filename = 'receipt_parsed.csv'
        df.to_csv(csv_filename, index=False, encoding='utf-8-sig')
        
        print("\n성공적으로 데이터를 파싱했습니다!")
        display(df)
        
        # 파일 다운로드 트리거
        files.download(csv_filename)
        print(f"'{csv_filename}' 파일이 다운로드 되었습니다.")
    else:
        print("\n텍스트는 추출되었으나, '상품명, 단가, 수량, 금액' 패턴을 찾지 못했습니다.")
        print("영수증 양식에 맞게 코드의 정규표현식(pattern) 부분을 수정해야 합니다.")
