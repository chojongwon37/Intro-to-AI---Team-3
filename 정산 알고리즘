    "items": [],         # Array of {"id": int, "name": str, "cost": int, "payer_name": str, "participant_names": list[str]}
    "item_counter": 0
}

# ----------------- 데이터 관리 함수 -----------------

def delete_participant(name):
    # 참여자 목록에서 제외
    state["participants"] = [p for p in state["participants"] if p["name"] != name]
    
    # 품목 데이터에서도 제외
    for item in state["items"]:
        if name in item["participant_names"]:
            item["participant_names"].remove(name)
        if item["payer_name"] == name:
            item["payer_name"] = ""  # 결제자 비움
            



def delete_item(item_id):
    state["items"] = [item for item in state["items"] if item["id"] != item_id]


def toggle_item_participant(item_id, p_name):
    for item in state["items"]:
        if item["id"] == item_id:
            if p_name in item["participant_names"]:
                item["participant_names"].remove(p_name)
            else:
                item["participant_names"].append(p_name)
            break
    


def calculate():
    if not state["participants"]:
        return
        
    if not state["items"]:
        return
        
    # 결제자 비어있는 품목 있는지 검사
    for item in state["items"]:
        if not item["payer_name"]:
            return
            
    # 정산 로직 구동용 데이터 객체 매핑
    participants_dict = {
        p["name"]: Participant(p["name"], p["bank"], p["account"])
        for p in state["participants"]
    }
    
    items_list = [
        Item(item["name"], item["cost"], item["payer_name"], item["participant_names"])
        for item in state["items"]
    ]
    
    rounding_unit = 10
    
    # 송금 최소화 연산 실행
    balances, transfers = calculate_dutch_pay(participants_dict, items_list, rounding_unit)
    
    # 텍스트 포맷팅
    result_text = format_results(participants_dict, items_list, transfers)
    
    return result_text

