def recognize_receipt_image(image_path):
    """
    영수증 이미지에서 품목명/금액을 추출해서 parsed_data 리스트로 반환합니다.
    필요한 설치:
    pip install easyocr opencv-python pandas numpy torch
    """
    try:
        import easyocr
        import cv2
        import numpy as np
        import re
        import torch
    except ImportError as e:
        messagebox.showerror(
            "OCR 모듈 오류",
            "OCR 기능에 필요한 모듈이 없습니다.\n\n"
            "터미널에서 아래 명령어를 실행하세요.\n"
            "pip install easyocr opencv-python pandas numpy torch\n\n"
            f"오류 내용: {e}"
        )
        return []

    use_gpu = torch.cuda.is_available()
    reader = easyocr.Reader(['ko', 'en'], gpu=use_gpu)

    img_array = np.fromfile(image_path, np.uint8)
    img = cv2.imdecode(img_array, cv2.IMREAD_COLOR)

    if img is None:
        messagebox.showerror("이미지 오류", "이미지를 불러올 수 없습니다.")
        return []

    img_resized = cv2.resize(img, None, fx=1.5, fy=1.5, interpolation=cv2.INTER_CUBIC)
    ocr_results = reader.readtext(img_resized)

    lines = []
    for box, text, prob in ocr_results:
        y_center = (box[0][1] + box[2][1]) / 2
        height = box[2][1] - box[0][1]
        x_start = box[0][0]
        lines.append({"text": text.strip(), "y": y_center, "h": height, "x": x_start})

    lines = sorted(lines, key=lambda x: x["y"])
    grouped_rows = []

    if lines:
        current_row = [lines[0]]
        for line in lines[1:]:
            ref_line = current_row[0]
            threshold = max(ref_line["h"], line["h"]) * 0.6
            if abs(line["y"] - ref_line["y"]) < threshold:
                current_row.append(line)
            else:
                grouped_rows.append(current_row)
                current_row = [line]
        grouped_rows.append(current_row)

    parsed_data = []
    total_keywords = [
        "합계", "TOTAL", "총금액", "총액", "결제금액",
        "받을금액", "받은금액", "발물", "룹액", "발물룹액"
    ]
    exclude_keywords = [
        "매장", "매장명", "사업자", "주소", "대표", "번호", "전화",
        "TEL", "일시", "부가세", "VAT", "과세", "면세", "거스름돈",
        "승인", "고객", "안내", "원", "영수증", "가맹점"
    ]

    for row in grouped_rows:
        sorted_row = sorted(row, key=lambda x: x["x"])
        row_text = " ".join([item["text"] for item in sorted_row])
        cleaned_text_for_check = row_text.replace(" ", "")

        if any(k in cleaned_text_for_check for k in total_keywords):
            continue

        if any(k in cleaned_text_for_check for k in ["단가", "수량", "금액", "품명"]):
            continue

        if any(k in cleaned_text_for_check for k in exclude_keywords):
            continue

        num_tokens = []
        name_tokens = []

        for item in reversed(sorted_row):
            t_text = item["text"]
            digit_only = re.sub(r"[^0-9]", "", t_text)

            if digit_only and any(c.isdigit() for c in t_text) and len(num_tokens) < 3:
                num_tokens.insert(0, int(digit_only))
            else:
                name_tokens.insert(0, t_text)

        if name_tokens and num_tokens:
            product_name = re.sub(
                r"^[=\-_※\*\s\.\+~:★▶\[\]\(\)]+|[=\-_※\*\s\.\+~:★▶\[\]\(\)]+$",
                "",
                " ".join(name_tokens)
            ).strip()

            if not product_name or product_name.isdigit() or len(product_name) < 2:
                continue

            if len(num_tokens) == 3:
                unit_price, quantity, price = num_tokens
            elif len(num_tokens) == 2:
                v1, v2 = num_tokens
                if v1 < 100:
                    quantity = v1
                    price = v2
                    unit_price = price // quantity if quantity > 0 else 0
                else:
                    unit_price = v1
                    price = v2
                    quantity = price // unit_price if unit_price > 0 else 1
            else:
                price = num_tokens[0]
                unit_price = price
                quantity = 1

            if quantity > 1000 or price > 10000000 or unit_price > 10000000:
                continue

            parsed_data.append({
                "상품명": product_name,
                "단가": unit_price,
                "수량": quantity,
                "금액": price
            })

    return parsed_data


