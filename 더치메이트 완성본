def generate_output():
    if not state["participants"]:
        messagebox.showwarning("데이터 부족", "참여자를 등록해 주세요.")
        return
    if not state["items"]:
        messagebox.showwarning("데이터 부족", "품목을 등록해 주세요.")
        return
    for item in state["items"]:
        if not item["payer_name"]:
            messagebox.showwarning("설정 미비", f"'{item['name']}' 품목의 결제자가 지정되지 않았습니다.")
            return

    participants_dict = {p["name"]: Participant(p["name"], p["bank"], p["account"]) for p in state["participants"]}
    items_list = [Item(item["name"], item["cost"], item["payer_name"], item["participant_names"]) for item in state["items"]]
    _, transfers = calculate_dutch_pay(participants_dict, items_list, rounding_unit=10)
    
    kakao_output = []
    kakao_output.append("📢 [모임 정산 알림]")
    kakao_output.append("정산이 완료되었습니다! 내역을 확인하고 송금해 주세요. 💸")
    kakao_output.append("━" * 35)
    kakao_output.append("\n📝 [품목별 상세 내역]")
    for i, item in enumerate(items_list, 1):
        num_p = len(item.participant_names)
        split_val = item.cost / num_p if num_p > 0 else 0
        kakao_output.append(f"{i}. {item.name}: {item.cost:,.0f}원 (결제자: {item.payer_name})")
        kakao_output.append(f"    └ 참여인원: {num_p}명 ({', '.join(item.participant_names)})")
        kakao_output.append(f"    └ 1인당 금액: {split_val:,.0f}원")
    kakao_output.append("\n💸 [송금 내역]")
    if not transfers:
        kakao_output.append("이체할 내역이 없습니다. 정산이 완벽히 맞습니다.")
    else:
        for idx, t in enumerate(transfers, 1):
            sender = t["from"]
            receiver = t["to"]
            amount = t["amount"]
            receiver_obj = participants_dict[receiver]
            account_info = ""
            toss_url_msg = ""
            if receiver_obj.bank and receiver_obj.account_number:
                account_info = f" ({receiver_obj.bank} {receiver_obj.account_number})"
                # 토스 앱 범용 커스텀 스키마 링크 생성 적용
                encoded_bank = urllib.parse.quote(receiver_obj.bank)
                toss_link = f"toss://send?bank={encoded_bank}&account={receiver_obj.account_number}&amount={int(amount)}"
                toss_url_msg = f"\n    ⚡ [터치 시 토스 자동 송금]: {toss_link}"
            else:
                toss_url_msg = f"\n    ⚠️ 계좌 정보가 등록되지 않았습니다."
            kakao_output.append(f"{idx}. {sender} ➔ {receiver}: {amount:,.0f}원{account_info}{toss_url_msg}")
            kakao_output.append("    -----------------------------------------")  
    kakao_output.append("\n💡 토스 링크를 누르면 금액과 계좌가 앱에 자동으로 입력됩니다.")
    kakao_output.append("━" * 35)
    final_text = "\n".join(kakao_output)
    text_area.delete("1.0", tk.END)
    text_area.insert(tk.END, final_text)
    
    if pyperclip:
        try:
            pyperclip.copy(final_text)
            messagebox.showinfo("복사 완료", "정산서가 클립보드에 복사되었습니다! 카톡방에 붙여넣기 하세요.")
        except Exception:
            pass



def copy_transfer_info_only():
    """정산 결과 중 송금해야 할 금액과 받는 사람 계좌만 클립보드에 복사"""
    if not state["participants"]:
        messagebox.showwarning("데이터 부족", "참여자를 먼저 등록해 주세요.")
        return
    if not state["items"]:
        messagebox.showwarning("데이터 부족", "품목을 먼저 등록해 주세요.")
        return

    for item in state["items"]:
        if not item.get("payer_name"):
            messagebox.showwarning("설정 미비", f"'{item['name']}' 품목의 결제자가 지정되지 않았습니다.")
            return
        if not item.get("participant_names"):
            messagebox.showwarning("설정 미비", f"'{item['name']}' 품목에 참여자가 없습니다.")
            return

    participants_dict = {
        p["name"]: Participant(p["name"], p.get("bank", ""), p.get("account", ""))
        for p in state["participants"]
    }
    items_list = [
        Item(item["name"], item["cost"], item["payer_name"], item["participant_names"])
        for item in state["items"]
    ]
    _, transfers = calculate_dutch_pay(participants_dict, items_list, rounding_unit=10)

    if not transfers:
        copy_text = "이체할 내역이 없습니다. 정산 완료!"
    else:
        lines = ["💸 송금 내역"]
        for idx, t in enumerate(transfers, 1):
            sender = t["from"]
            receiver = t["to"]
            amount = int(t["amount"])
            receiver_obj = participants_dict[receiver]

            if receiver_obj.bank and receiver_obj.account_number:
                account_info = f"{receiver_obj.bank} {receiver_obj.account_number}"
            else:
                account_info = "계좌 정보 미등록"

            lines.append(f"{idx}. {sender} → {receiver}: {amount:,}원 / {account_info}")
        copy_text = "\n".join(lines)

    try:
        root.clipboard_clear()
        root.clipboard_append(copy_text)
        root.update()
        messagebox.showinfo("복사 완료", "송금 금액과 계좌 정보를 클립보드에 복사했습니다.")
    except Exception as e:
        messagebox.showerror("복사 실패", f"클립보드 복사 중 오류가 발생했습니다:\n{e}")

