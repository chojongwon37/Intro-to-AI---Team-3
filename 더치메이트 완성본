def create_toss_link(bank_name, account_number, send_amount):
    if not bank_name or not account_number:
        return None
    encoded_bank = urllib.parse.quote(bank_name)
    return f"toss://send?bank={encoded_bank}&account={account_number}&amount={int(send_amount)}"


