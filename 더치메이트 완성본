def load_receipt_ocr():
    # 1단계 친구가 한 명도 없으면 결제자 지정이 불가능하므로 경고 안내
    if not state["participants"]:
        messagebox.showwarning("참여자 부족", "영수증을 스캔하기 전에 '1단계'에서 최소 1명 이상의 친구를 먼저 등록해 주세요!")
        return

    image_path = filedialog.askopenfilename(
        title="영수증 이미지 파일 선택",
        filetypes=[("Image Files", "*.jpg;*.jpeg;*.png;*.bmp"), ("All Files", "*.*")]
    )

    if not image_path or not os.path.exists(image_path):
        return

    img_array = np.fromfile(image_path, np.uint8)
    img = cv2.imdecode(img_array, cv2.IMREAD_COLOR)

    if img is None:
        messagebox.showerror("오류", "이미지를 불러오는 데 실패했습니다.")
        return

    img_resized = cv2.resize(img, None, fx=1.5, fy=1.5, interpolation=cv2.INTER_CUBIC)

    print("\n[OCR 분석 중...]")
    ocr_results = reader.readtext(img_resized)

    lines = []
    for box, text, prob in ocr_results:
        y_center = (box[0][1] + box[2][1]) / 2
        height = box[2][1] - box[0][1]
        x_start = box[0][0]
        lines.append({
            "text": text.strip(),
            "y": y_center,
            "h": height,
            "x": x_start
        })

    lines = sorted(lines, key=lambda x: x["y"])

    grouped_rows = []
    if lines:
        current_row = [lines[0]]
        for line in lines[1:]:
            ref_line = current_row[0]
            threshold = max(ref_line["h"], line["h"]) * 0.6

            if abs(line["y"] - ref_line["y"]) < threshold:
                current_row.append(line)
            else:
                grouped_rows.append(current_row)
                current_row = [line]
        grouped_rows.append(current_row)

    total_keywords = ["합계", "TOTAL", "총금액", "총액", "결제금액", "받을금액", "받은금액"]
    exclude_keywords = [
        "매장", "사업자", "주소", "대표", "번호", "전화", "TEL",
        "일시", "부가세", "VAT", "과세", "면세", "거스름돈",
        "승인", "고객", "안내", "영수증", "가맹점", "단가", "수량", "금액", "품명"
    ]

    added_count = 0
    # 1단계 목록의 첫 번째 사람을 영수증 기본 결제자로 스마트 지정
    default_payer = state["participants"][0]["name"]

    for row in grouped_rows:
        sorted_row = sorted(row, key=lambda x: x["x"])
        row_text = " ".join([item["text"] for item in sorted_row])
        check_text = row_text.replace(" ", "")

        if any(k in check_text for k in total_keywords): continue
        if any(k in check_text for k in exclude_keywords): continue

        num_tokens = []
        name_tokens = []

        for item in reversed(sorted_row):
            t_text = item["text"]
            digit_only = re.sub(r"[^0-9]", "", t_text)

            if digit_only and len(num_tokens) < 3:
                num_tokens.insert(0, int(digit_only))
            else:
                name_tokens.insert(0, t_text)

        if name_tokens and num_tokens:
            product_name = " ".join(name_tokens).strip()
            product_name = re.sub(r"^[=\-_※\*\s\.\+~:★▶\[\]\(\)]+|[=\-_※\*\s\.\+~:★▶\[\]\(\)]+$", "", product_name)

            if not product_name or product_name.isdigit() or len(product_name) < 2:
                continue

            if len(num_tokens) == 3:
                unit_price, quantity, price = num_tokens
            elif len(num_tokens) == 2:
                v1, v2 = num_tokens
                if v1 < 100:
                    price = v2
                else:
                    price = v2
            else:
                price = num_tokens[0]

            if price <= 0 or price > 10000000:
                continue

            # 🚀 [핵심 수정] 추출한 품목을 앱 전체 State 시스템에 안전하게 보관!
            state["item_counter"] += 1
            state["items"].append({
                "id": state["item_counter"],
                "name": product_name,
                "cost": price,
                "payer_name": default_payer,
                "participant_names": [p["name"] for p in state["participants"]] # 등록된 전원 참여 기본값
            })
            added_count += 1

    # 🚀 품목 진열 리스트박스 화면 실시간 새로고침 호출!
    update_item_ui()
    
    if added_count > 0:
        messagebox.showinfo("스캔 완료", f"영수증 인식 성공!\n총 {added_count}개의 품목이 하단 리스트에 진열되었습니다.\n(결제자 기본값: {default_payer})")
    else:
        messagebox.showwarning("인식 실패", "영수증에서 유효한 품목 정보를 추출하지 못했습니다.")

def delete_participant(name):
    state["participants"] = [p for p in state["participants"] if p["name"] != name]
    for item in state["items"]:
        if name in item["participant_names"]:
            item["participant_names"].remove(name)
        if item["payer_name"] == name:
            item["payer_name"] = ""  
    update_participant_ui()
    update_payer_dropdown()
    update_item_ui()

def delete_item(item_id):
    state["items"] = [item for item in state["items"] if item["id"] != item_id]
    update_item_ui()

def toggle_item_participant(item_id, p_name):
    for item in state["items"]:
        if item["id"] == item_id:
            if p_name in item["participant_names"]:
                item["participant_names"].remove(p_name)
            else:
                item["participant_names"].append(p_name)
            break
    update_item_ui()

def change_item_payer(item_id, new_payer):
    """품목별 결제자를 드롭다운에서 변경"""
    if not new_payer or new_payer == "선택":
        return
    for item in state["items"]:
        if item["id"] == item_id:
            item["payer_name"] = new_payer
            break
    update_item_ui()

