def set_item_participant(item_id, p_name, checked):
    """품목 카드 안에서 참여자를 체크박스로 켜고 끄는 함수"""
    for item in state["items"]:
        if item["id"] == item_id:
            if checked:
                if p_name not in item["participant_names"]:
                    item["participant_names"].append(p_name)
            else:
                if p_name in item["participant_names"]:
                    item["participant_names"].remove(p_name)
            break
    refresh_item_listbox_only()


