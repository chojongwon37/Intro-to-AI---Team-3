# ----------------- 앱 상태(State) -----------------
state = {
    "participants": [],
    "items": [],
    "item_counter": 0
}

# ----------------- 토스 링크 생성 함수 -----------------
def create_toss_link(bank_name, account_number, send_amount):
    if not bank_name or not account_number:
        return None
    encoded_bank = urllib.parse.quote(bank_name)
    return f"toss://send?bank={encoded_bank}&account={account_number}&amount={int(send_amount)}"

# ----------------- 데이터 관리 함수 (GUI 연동 버전) -----------------
def delete_participant(name):
    state["participants"] = [p for p in state["participants"] if p["name"] != name]
    for item in state["items"]:
        if name in item["participant_names"]:
            item["participant_names"].remove(name)
        if item["payer_name"] == name:
            item["payer_name"] = ""
    update_participant_ui()
    update_payer_dropdown()
    update_item_ui()

def delete_item(item_id):
    state["items"] = [item for item in state["items"] if item["id"] != item_id]
    update_item_ui()

def toggle_item_participant(item_id, p_name):
    for item in state["items"]:
        if item["id"] == item_id:
            if p_name in item["participant_names"]:
                item["participant_names"].remove(p_name)
            else:
                item["participant_names"].append(p_name)
            break
    update_item_ui()

# ----------------- GUI 입력 버튼 동작 로직 -----------------
def add_participant_gui():
    name = entry_p_name.get().strip()
    bank = val_bank.get()
    account = entry_p_account.get().strip()
    
    if not name:
        messagebox.showwarning("입력 오류", "참여자 이름을 입력하세요.")
        return
    if any(p["name"] == name for p in state["participants"]):
        messagebox.showwarning("중복 오류", "이미 등록된 이름입니다.")
        return
    if bank == "은행 선택":
        bank = ""

    state["participants"].append({"name": name, "bank": bank, "account": account})
    entry_p_name.delete(0, tk.END)
    entry_p_account.delete(0, tk.END)
    val_bank.set("은행 선택")
    
    update_participant_ui()
    update_payer_dropdown()
    update_item_ui()

def update_participant_ui():
    listbox_participants.delete(0, tk.END)
    for p in state["participants"]:
        acc_info = f" ({p['bank']} {p['account']})" if p['bank'] else ""
        listbox_participants.insert(tk.END, f"{p['name']}{acc_info}")

def update_payer_dropdown():
    menu = menu_payer['menu']
    menu.delete(0, tk.END)
    if not state["participants"]:
        val_payer.set("선택")
        return
    val_payer.set(state["participants"][0]["name"])
    for p in state["participants"]:
        menu.add_command(label=p["name"], command=lambda v=p["name"]: val_payer.set(v))

def add_item_gui():
    name = entry_i_name.get().strip()
    cost_str = entry_i_cost.get().strip()
    payer = val_payer.get()
    
    if not name or not cost_str:
        messagebox.showwarning("입력 오류", "품목명과 금액을 입력하세요.")
        return
    try:
        cost = int(cost_str)
    except ValueError:
        messagebox.showwarning("입력 오류", "금액은 숫자만 입력 가능합니다.")
        return
    if payer == "선택" or not payer:
        messagebox.showwarning("설정 오류", "결제자를 지정할 참여자가 없습니다.")
        return

    state["item_counter"] += 1
    selected_participants = []
    for p_name, var in check_vars.items():
        if var.get():
            selected_participants.append(p_name)
            
    if not selected_participants:
        selected_participants = [p["name"] for p in state["participants"]]

    state["items"].append({
        "id": state["item_counter"],
        "name": name,
        "cost": cost,
        "payer_name": payer,
        "participant_names": selected_participants
    })
    
    entry_i_name.delete(0, tk.END)
    entry_i_cost.delete(0, tk.END)
    update_item_ui()

def update_item_ui():
    listbox_items.delete(0, tk.END)
    for item in state["items"]:
        listbox_items.insert(tk.END, f"[{item['id']}] {item['name']} ({item['cost']:,}원) / 결제: {item['payer_name']} / 참여: {len(item['participant_names'])}명")
        
    for widget in scroll_p_frame.winfo_children():
        widget.destroy()
        
    global check_vars
    check_vars = {}
    for p in state["participants"]:
        var = tk.BooleanVar(value=True)
        check_vars[p["name"]] = var
        cb = tk.Checkbutton(scroll_p_frame, text=p["name"], variable=var, bg="#ffffff", activebackground="#ffffff")
        cb.pack(anchor="w", padx=5, pady=2)

def delete_selected_participant():
    try:
        idx = listbox_participants.curselection()[0]
        p_name = state["participants"][idx]["name"]
        delete_participant(p_name)
    except IndexError:
        messagebox.showwarning("선택 오류", "삭제할 참여자를 목록에서 선택하세요.")

def delete_selected_item():
    try:
        idx = listbox_items.curselection()[0]
        item_id = state["items"][idx]["id"]
        delete_item(item_id)
    except IndexError:
        messagebox.showwarning("선택 오류", "삭제할 품목을 목록에서 선택하세요.")

# ----------------- GUI 연동 정산 처리 및 카톡 연동 로직 -----------------
def generate_output():
    if not state["participants"]:
        messagebox.showwarning("데이터 부족", "참여자를 등록해 주세요.")
        return
    if not state["items"]:
        messagebox.showwarning("데이터 부족", "품목을 등록해 주세요.")
        return

    # [원래 알고리즘 연동] 사용자가 선언한 Participant 및 Item 클래스로 매핑
    participants_dict = {p["name"]: Participant(p["name"], p["bank"], p["account"]) for p in state["participants"]}
    items_list = [Item(item["name"], item["cost"], item["payer_name"], item["participant_names"]) for item in state["items"]]
    
    # [원래 알고리즘 연동] 오리지널 정산 함수 실행 (절삭 단위 10원 고정)
    _, transfers = calculate_dutch_pay(participants_dict, items_list, rounding_unit=10)
    
    # 📱 카카오톡 공유 포맷 메시지 작성 시작
    kakao_output = []
    kakao_output.append("📢 [모임 정산 알림]")
    kakao_output.append("정산이 완료되었습니다! 내역을 확인하고 송금해 주세요. 💸")
    kakao_output.append("━" * 35)
    
    kakao_output.append("\n📝 [품목별 상세 내역]")
    for i, item in enumerate(items_list, 1):
        num_p = len(item.participant_names)
        split_val = item.cost / num_p if num_p > 0 else 0
        kakao_output.append(f"{i}. {item.name}: {item.cost:,.0f}원 (결제자: {item.payer_name})")
        kakao_output.append(f"   └ 참여인원: {num_p}명 ({', '.join(item.participant_names)})")
        kakao_output.append(f"   └ 1인당 금액: {split_val:,.0f}원")
        
    kakao_output.append("\n💸 [송금 내역]")
    if not transfers:
        kakao_output.append("이체할 내역이 없습니다. 정산이 완벽히 맞습니다.")
    else:
        for idx, t in enumerate(transfers, 1):
            sender = t["from"]
            receiver = t["to"]
            amount = t["amount"]
            receiver_obj = participants_dict[receiver]
            
            account_info = ""
            toss_url_msg = ""
            
            if receiver_obj.bank and receiver_obj.account_number:
                account_info = f" ({receiver_obj.bank} {receiver_obj.account_number})"
                toss_link = create_toss_link(receiver_obj.bank, receiver_obj.account_number, amount)
                if toss_link:
                    toss_url_msg = f"\n   ⚡ [터치 시 토스 자동 송금]: {toss_link}"
            else:
                toss_url_msg = f"\n   ⚠️ 계좌 정보가 등록되지 않았습니다."
                
            kakao_output.append(f"{idx}. {sender} ➔ {receiver}: {amount:,.0f}원{account_info}{toss_url_msg}")
            kakao_output.append("   -----------------------------------------")
        
    kakao_output.append("\n💡 토스 링크를 누르면 금액과 계좌가 앱에 자동으로 입력됩니다.")
    kakao_output.append("━" * 35)
    
    final_text = "\n".join(kakao_output)
    text_area.delete("1.0", tk.END)
    text_area.insert(tk.END, final_text)
    
    if pyperclip:
        try:
            pyperclip.copy(final_text)
            messagebox.showinfo("복사 완료", "정산서가 클립보드에 복사되었습니다! 카톡방에 붙여넣기 하세요.")
        except Exception:
            pass

